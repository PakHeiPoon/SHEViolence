.esc {
  position: fixed;
  right: 28rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: var(--ink, #1c191f); /* 暖芽墨黑胶囊 */
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  letter-spacing: 2rpx;
  box-shadow: 0 14rpx 36rpx rgba(28, 25, 31, 0.28);
  opacity: 0.94;
  z-index: 999;
}
.esc-hover { transform: scale(0.94); opacity: 1; }
