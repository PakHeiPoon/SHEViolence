/* 共享聊天 UI ·「暖芽」风（暖暖倾诉 / 法律问答 通用） */
.chatbox { display: flex; flex-direction: column; height: 100vh; }

.msgs { flex: 1; min-height: 0; padding: 12rpx 28rpx; box-sizing: border-box; }
.welcome { text-align: center; padding: 48rpx 30rpx 30rpx; }
.w-emoji { font-size: 72rpx; }
.w-mascot { width: 320rpx; height: 270rpx; }
.w-title {
  font-family: "Songti SC", "STSong", "Noto Serif SC", serif;
  font-size: var(--font-feature);
  font-weight: 700;
  line-height: 1.42;
  margin-top: 10rpx;
}
.w-sub { margin-top: 14rpx; color: #aaa6ae; font-size: var(--font-meta); }
.chips { display: flex; flex-direction: column; gap: 16rpx; margin-top: 40rpx; }
.chip {
  background: #FDFDFD;
  border: 1rpx solid #FFFFFF;
  border-radius: 44rpx;
  padding: 20rpx 30rpx;
  font-size: 27rpx;
  color: var(--text);
  box-shadow: var(--shadow-float);
}

.row { display: flex; margin: 18rpx 0; }
.row.right { justify-content: flex-end; }
.row.left { justify-content: flex-start; }
.bubble { max-width: 78%; padding: 20rpx 26rpx; font-size: 29rpx; line-height: 1.7; word-break: break-all; }
.bubble.user {
  background: var(--ink);
  color: #fff;
  border-radius: 28rpx 28rpx 8rpx 28rpx;
  box-shadow: 0 10rpx 26rpx rgba(28, 25, 31, 0.16);
}
.bubble.ai {
  background: var(--surface);
  border: 1rpx solid rgba(25, 23, 28, 0.06);
  border-radius: 28rpx 28rpx 28rpx 8rpx;
  box-shadow: var(--shadow);
}
.bubble-img { width: 320rpx; max-width: 58vw; border-radius: 18rpx; display: block; margin-bottom: 8rpx; }

.sources { margin-top: 16rpx; border-top: 1rpx dashed var(--border); padding-top: 12rpx; }
.src { font-size: var(--font-caption); color: var(--muted); margin-top: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.src-ref { color: var(--apricot); font-weight: 700; margin-right: 8rpx; }

.typing { display: flex; gap: 10rpx; align-items: center; padding: 26rpx 30rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--apricot); animation: blink 1.2s infinite; }
.d2 { animation-delay: 0.2s; }
.d3 { animation-delay: 0.4s; }
@keyframes blink { 0%, 100% { opacity: 0.25; } 50% { opacity: 1; } }
.status-text { font-size: var(--font-meta); color: var(--muted); margin-left: 4rpx; }

/* 输入条：暖芽浮起胶囊 composer */
.input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 12rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  padding: 10rpx 12rpx 10rpx 18rpx;
  border: 1rpx solid rgba(28, 25, 33, 0.04);
  border-radius: 56rpx;
  background: #fff;
  box-shadow: 0 20rpx 62rpx rgba(35, 31, 45, 0.10);
}
.input { flex: 1; min-width: 0; padding: 14rpx 12rpx; font-size: 29rpx; }
.ph { color: #9a979f; }
.icon-btn {
  width: 72rpx; height: 72rpx; flex-shrink: 0;
  border-radius: 50%;
  background: var(--surface-2);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
}
.icon-btn.on { transform: scale(0.92); }
.icon-btn.recing { background: var(--danger-soft); animation: recPulse 1s ease-in-out infinite; }
@keyframes recPulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.12); } }

.send {
  background: var(--ink);
  color: #fff;
  font-size: var(--font-body);
  font-weight: 700;
  padding: 18rpx 34rpx;
  border-radius: 44rpx;
  flex-shrink: 0;
}
.send.disabled { opacity: 0.5; }

/* 录音状态提示 */
.rec-pill {
  align-self: center;
  margin: 0 auto 10rpx;
  background: rgba(25, 23, 28, 0.86);
  color: #fff;
  font-size: var(--font-meta);
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  width: fit-content;
}

/* 危机 Banner：淡红卡 + 紧急红 */
.crisis { padding: 22rpx 28rpx; animation: slideDown 0.3s ease; }
@keyframes slideDown { from { transform: translateY(-100%); } to { transform: translateY(0); } }
.crisis.lv2 { background: var(--danger-soft); border-bottom: 1rpx solid rgba(214, 69, 65, 0.18); }
.crisis.lv3 { background: var(--danger-soft); border-bottom: 2rpx solid rgba(214, 69, 65, 0.35); }
.crisis-text { font-size: 26rpx; font-weight: 700; color: var(--danger); }
.crisis-actions { display: flex; align-items: center; gap: 16rpx; margin-top: 14rpx; }
.crisis-btn { font-size: 26rpx; font-weight: 700; padding: 12rpx 28rpx; border-radius: 44rpx; color: #fff; }
.b110 { background: var(--danger); }
.b12338 { background: var(--ink); }
.crisis-close { margin-left: auto; color: var(--muted); font-size: 30rpx; padding: 4rpx 12rpx; }
