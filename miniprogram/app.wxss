/**
 * 设计系统 ·「暖芽」（移植自队友 UI修改 分支的设计语言）
 * 冷调纸白 + 墨黑胶囊 + 薰衣草紫点缀 + 四色淡彩功能块 + 宋体大标题
 * 伪装页刻意不用这套（平庸记账风），解锁瞬间形成强反差。
 */
page {
  /* 字号分级（源自暖芽 12 级字阶） */
  --font-micro: 20rpx;
  --font-caption: 22rpx;
  --font-meta: 24rpx;
  --font-body: 28rpx;
  --font-section: 34rpx;
  --font-nav: 38rpx;
  --font-feature: 46rpx;
  --font-intro: 56rpx;
  --font-display: 66rpx;
  --font-emergency: 104rpx;

  /* 色板 */
  --bg: #FBFCFC;             /* 冷调纸白 */
  --surface: #FFFFFF;
  --surface-2: #f1eff3;
  --border: #e8e6ea;
  --text: #19171c;           /* 墨黑 */
  --muted: #96929b;
  --ink: #1c191f;            /* 黑胶囊主行动色 */

  --apricot: #745fc1;        /* （沿用变量名）强调色 → 薰衣草紫 */
  --apricot-deep: #5B3AA4;
  --apricot-soft: #eeebff;   /* 淡紫块 */
  --sage: #3f7d5a;           /* 安全/认证绿（柔和化） */
  --sage-soft: #eef4f0;      /* 淡绿块 */
  --danger: #D64541;         /* 紧急红（仅危机场景） */
  --danger-soft: #f9e6e5;    /* 淡红块 */
  --amber-soft: #fff0e3;     /* 淡橙块 */

  --shadow: 0 12rpx 36rpx rgba(35, 31, 45, 0.05);
  --shadow-float: 0 18rpx 50rpx rgba(32, 29, 39, 0.08);

  background: var(--bg);
  color: var(--text);
  font-size: var(--font-body);
  line-height: 1.65;
  font-family: "Avenir Next", -apple-system, "PingFang SC", "Hiragino Sans GB", sans-serif;
}

/* 宋体标题（暖芽人文签名） */
.serif, .h1 {
  font-family: "Songti SC", "STSong", "Noto Serif SC", serif;
}

/* ---------- 通用卡片：轻盈悬浮 ---------- */
.card {
  background: var(--surface);
  border: 1rpx solid rgba(25, 23, 28, 0.06);
  border-radius: 24rpx;
  box-shadow: var(--shadow);
  padding: 28rpx;
  box-sizing: border-box;
}

.h1 { font-size: 44rpx; font-weight: 700; letter-spacing: 1rpx; }
.h2 { font-size: var(--font-section); font-weight: 700; }
.muted { color: var(--muted); font-size: var(--font-meta); }

/* ---------- 按钮：墨黑胶囊为主 ---------- */
.btn {
  border-radius: 44rpx;
  font-size: var(--font-body);
  font-weight: 700;
  padding: 20rpx 40rpx;
  line-height: 1.4;
  border: none;
}
.btn::after { border: none; }
.btn-primary { background: var(--ink); color: #fff; }
.btn-ghost { background: var(--surface); color: var(--ink); border: 1rpx solid rgba(28, 25, 31, 0.16); }
.btn-sage { background: var(--sage); color: #F4FAF4; }
.btn-danger { background: var(--danger); color: #FFF6F2; }

/* ---------- 标签 ---------- */
.tag {
  display: inline-flex;
  align-items: center;
  font-size: var(--font-caption);
  font-weight: 600;
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
  background: var(--surface-2);
  color: var(--muted);
}
.tag-sage { background: var(--sage-soft); color: var(--sage); }
.tag-apricot { background: var(--apricot-soft); color: var(--apricot-deep); }
.tag-danger { background: var(--danger-soft); color: var(--danger); }

/* ---------- 浮起白 pill（暖芽签名元素） ---------- */
.pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 32rpx;
  height: 78rpx;
  border: 1rpx solid #FFFFFF;
  border-radius: 44rpx;
  background: #FDFDFD;
  box-shadow: var(--shadow-float);
  font-size: var(--font-body);
  font-weight: 700;
}

/* ---------- 进场动画 ---------- */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(28rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.fade-up { animation: fadeUp 0.5s ease both; }
.delay-1 { animation-delay: 0.06s; }
.delay-2 { animation-delay: 0.14s; }
.delay-3 { animation-delay: 0.22s; }
.delay-4 { animation-delay: 0.30s; }
.delay-5 { animation-delay: 0.38s; }

/* SOS 呼吸（红调柔影） */
@keyframes breathe {
  0%, 100% { transform: scale(1); box-shadow: 0 10rpx 30rpx rgba(214, 69, 65, 0.10); }
  50% { transform: scale(1.012); box-shadow: 0 16rpx 46rpx rgba(214, 69, 65, 0.16); }
}
.breathe { animation: breathe 2.6s ease-in-out infinite; }

/* 页面底部安全区留白 */
.safe-bottom { padding-bottom: calc(160rpx + env(safe-area-inset-bottom)); }
