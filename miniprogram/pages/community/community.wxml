<view class="comm safe-bottom">

  <view class="head-note fade-up">🎭 所有成员均为匿名身份 · 专业回复带认证角标 · 发帖时间做了模糊处理</view>

  <!-- 标签筛选 -->
  <scroll-view class="tags" scroll-x>
    <view class="tag-item {{activeTag === item ? 'on' : ''}}" wx:for="{{tags}}" wx:key="*this"
      bindtap="switchTag" data-tag="{{item}}">{{item}}</view>
  </scroll-view>

  <!-- 帖子列表 -->
  <view class="posts">
    <view class="post card fade-up" wx:for="{{shown}}" wx:key="id" bindtap="toggle" data-id="{{item.id}}">
      <view class="post-top">
        <view class="tag tag-sage">{{item.tag}}</view>
        <view class="post-time">{{item.time}}</view>
        <view class="post-report" catchtap="report">举报</view>
      </view>
      <view class="post-title">{{item.title}}</view>
      <view class="post-content">{{item.content}}</view>
      <view class="post-meta">🤍 {{item.likes}} · {{item.replies.length}} 条回复 {{expandedId === item.id ? '▲' : '▼'}}</view>

      <view class="replies" wx:if="{{expandedId === item.id}}">
        <view class="reply" wx:for="{{item.replies}}" wx:for-item="r" wx:key="index">
          <view class="reply-head">
            <text class="reply-name">{{r.name}}</text>
            <view class="cert" wx:if="{{r.cert}}">✓ {{r.cert}}</view>
          </view>
          <view class="reply-content">{{r.content}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 发帖入口 -->
  <view class="fab" bindtap="newPost">✏️</view>

  <app-dock active="community" />
</view>
