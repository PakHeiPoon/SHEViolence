.risk { padding: 28rpx; }

/* 引导 */
.intro { text-align: center; padding: 60rpx 40rpx; }
.intro-emoji { font-size: 80rpx; }
.intro-title { font-size: 36rpx; font-weight: 800; margin-top: 20rpx; }
.intro-sub { font-size: 26rpx; color: var(--muted); margin-top: 16rpx; line-height: 1.8; text-align: left; }
.intro-btn { margin-top: 44rpx; width: 100%; }

/* 答题 */
.progress { font-size: 24rpx; color: var(--muted); margin: 4rpx 4rpx 20rpx; }
.q { margin-bottom: 20rpx; padding: 28rpx; }
.q-text { font-size: 29rpx; font-weight: 600; line-height: 1.7; }
.opts { display: flex; gap: 20rpx; margin-top: 22rpx; }
.opt {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 999rpx;
  background: var(--surface-2);
  color: var(--muted);
  font-size: 27rpx;
  font-weight: 600;
  border: 2rpx solid transparent;
}
.opt.sel {
  background: var(--apricot-soft);
  color: var(--apricot-deep);
  border-color: var(--apricot);
}
.submit { width: 100%; margin-top: 12rpx; }
.submit.dim { opacity: 0.45; }

/* 结果 */
.res { text-align: center; padding: 48rpx 32rpx; }
.res-label { font-size: 24rpx; color: var(--muted); letter-spacing: 4rpx; }
.res-level { font-size: 56rpx; font-weight: 800; margin-top: 12rpx; }
.res-score { font-size: 24rpx; color: var(--muted); margin-top: 10rpx; }
.lv-low .res-level { color: var(--sage); }
.lv-medium .res-level { color: #C08A2D; }
.lv-high .res-level { color: var(--apricot-deep); }
.lv-critical .res-level { color: var(--danger); }

.sec { margin-top: 20rpx; padding: 28rpx; }
.sec-title { font-size: 28rpx; font-weight: 700; margin-bottom: 16rpx; }
.sec-body { font-size: 27rpx; line-height: 1.8; color: var(--text); }

.sug { display: flex; gap: 18rpx; margin-bottom: 18rpx; align-items: flex-start; }
.sug:last-child { margin-bottom: 0; }
.sug-idx {
  width: 40rpx; height: 40rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: var(--sage-soft);
  color: var(--sage);
  font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin-top: 4rpx;
}
.sug-text { font-size: 27rpx; line-height: 1.7; }

.res-line {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx dashed var(--border);
}
.res-line:last-child { border-bottom: none; }
.res-name { font-size: 28rpx; font-weight: 700; }
.res-desc { font-size: 22rpx; color: var(--muted); margin-top: 2rpx; }
.res-call {
  background: var(--sage);
  color: #F4FAF4;
  font-size: 24rpx; font-weight: 700;
  padding: 10rpx 30rpx;
  border-radius: 999rpx;
}

.foot-note { font-size: 22rpx; color: var(--muted); text-align: center; margin: 24rpx 20rpx; line-height: 1.7; }
.btn-row { display: flex; gap: 20rpx; }
.btn-row .btn { flex: 1; }
