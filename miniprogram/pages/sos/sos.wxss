.sos-page { padding: 8rpx 0 0; }
.press { opacity: 0.88; }

.title-block { padding: 30rpx 40rpx 26rpx; }
.page-title {
  display: block;
  font-family: "Songti SC", "STSong", "Noto Serif SC", serif;
  font-size: var(--font-display);
  font-weight: 700;
}
.page-subtitle { display: block; margin-top: 10rpx; color: var(--muted); font-size: var(--font-meta); }

/* 紧急热线大字卡 */
.emergency-card {
  margin: 0 36rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  background: var(--danger-soft);
  box-shadow: 0 18rpx 46rpx rgba(126, 53, 49, 0.08);
}
.emergency-top { display: flex; align-items: center; justify-content: space-between; }
.phone-icon-window {
  display: flex; width: 72rpx; height: 72rpx;
  align-items: center; justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  font-size: 34rpx;
}
.danger-status {
  padding: 9rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.64);
  color: var(--danger);
  font-size: var(--font-caption);
  font-weight: 600;
}
.emergency-label { display: block; margin-top: 26rpx; font-size: var(--font-body); font-weight: 700; }
.emergency-number {
  display: block;
  margin-top: 2rpx;
  font-family: "Avenir Next", sans-serif;
  font-size: var(--font-emergency);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: 4rpx;
}
.emergency-action {
  display: flex; height: 84rpx;
  align-items: center; justify-content: space-between;
  margin-top: 18rpx; padding: 0 28rpx;
  border-radius: 44rpx;
  background: var(--ink);
  color: #fff;
  font-size: var(--font-body);
  font-weight: 700;
}
.emergency-action text:last-child { font-size: 34rpx; }
.silent-tip { display: block; margin-top: 18rpx; color: rgba(25, 23, 28, 0.55); font-size: var(--font-meta); line-height: 1.55; }

.section-title-local { display: block; margin: 42rpx 40rpx 16rpx; font-size: var(--font-section); font-weight: 700; }

/* 快速行动格（四色淡彩） */
.quick-grid { display: grid; gap: 14rpx; padding: 0 36rpx; }
.quick-action {
  display: grid;
  min-height: 104rpx;
  grid-template-columns: 58rpx minmax(0, 1fr) auto;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 22rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
}
.quick-action.medical { background: var(--sage-soft); }
.quick-action.rights { background: var(--amber-soft); }
.quick-action.location { background: var(--apricot-soft); }
.quick-action.support { background: #eeebff; }
.quick-action.ribbon { background: #fff; border: 1rpx solid #efedf1; }
.quick-value.small { font-size: var(--font-caption); }

/* 12110 短信报警卡 */
.sms-card { display: flex; align-items: center; gap: 16rpx; margin: 14rpx 36rpx 0; padding: 22rpx 26rpx; border: 1rpx solid #efedf1; border-radius: 24rpx; background: #fff; box-shadow: 0 10rpx 28rpx rgba(35,31,45,0.04); }
.sms-icon { font-size: 36rpx; }
.sms-copy { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.sms-title { font-size: var(--font-caption); font-weight: 700; }
.sms-note { font-size: var(--font-meta); color: var(--muted); }
.sms-act { flex: 0 0 auto; font-size: var(--font-caption); font-weight: 700; color: #745fc1; background: #eeebff; border-radius: 999rpx; padding: 10rpx 26rpx; }

/* 机构名录入口 */
.orgs-link { display: flex; align-items: center; justify-content: space-between; margin: 16rpx 36rpx 0; padding: 24rpx 28rpx; border-radius: 24rpx; background: #1c191f; color: #fff; font-size: var(--font-caption); font-weight: 600; }
.orgs-arrow { font-size: 32rpx; opacity: 0.7; }
.quick-icon {
  display: flex; width: 54rpx; height: 54rpx;
  align-items: center; justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.76);
  font-size: 27rpx;
}
.quick-copy text { display: block; }
.quick-title { font-size: var(--font-body); font-weight: 700; }
.quick-note { margin-top: 4rpx; color: rgba(25, 23, 28, 0.5); font-size: var(--font-caption); }
.quick-value { font-size: var(--font-section); font-weight: 700; font-family: "Avenir Next", sans-serif; }
.quick-value.arrow { font-size: 34rpx; }

/* 安全三步 */
.safety-steps { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12rpx; padding: 0 36rpx; }
.safety-step {
  display: flex;
  min-height: 190rpx;
  flex-direction: column;
  padding: 22rpx 18rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--border);
  border-radius: 24rpx;
  background: var(--surface);
}
.step-icon {
  display: flex; width: 46rpx; height: 46rpx;
  align-items: center; justify-content: center;
  border-radius: 50%;
  background: var(--surface-2);
  font-size: 23rpx;
}
.step-title { margin-top: 16rpx; font-size: var(--font-body); font-weight: 700; }
.step-note { margin-top: 7rpx; color: var(--muted); font-size: var(--font-caption); line-height: 1.45; }

/* 紧急联系人 */
.contact-group { margin: 0 36rpx; border: 1rpx solid var(--border); border-radius: 26rpx; overflow: hidden; background: var(--surface); }
.contact-row {
  display: flex; min-height: 96rpx;
  align-items: center; gap: 16rpx;
  padding: 16rpx 22rpx;
  border-bottom: 1rpx solid var(--border);
}
.contact-row:last-child { border-bottom: 0; }
.contact-icon {
  display: flex; width: 48rpx; height: 48rpx;
  align-items: center; justify-content: center;
  border-radius: 50%;
  background: var(--surface-2);
  font-size: 22rpx;
  flex-shrink: 0;
}
.contact-copy { flex: 1; min-width: 0; }
.contact-copy text { display: block; }
.contact-copy text:first-child { font-size: var(--font-body); font-weight: 700; }
.contact-copy text:last-child { margin-top: 4rpx; color: var(--muted); font-size: var(--font-caption); }
.contact-call {
  background: var(--ink);
  color: #fff;
  font-size: var(--font-meta);
  font-weight: 700;
  padding: 12rpx 30rpx;
  border-radius: 44rpx;
}
.contact-empty {
  margin: 0 36rpx;
  padding: 30rpx;
  border: 1rpx dashed var(--border);
  border-radius: 24rpx;
  text-align: center;
  color: var(--muted);
  font-size: var(--font-meta);
}
