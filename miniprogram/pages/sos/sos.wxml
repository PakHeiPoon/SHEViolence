<view class="sos-page safe-bottom">

  <view class="title-block fade-up">
    <text class="page-title">别怕，帮助就在身边</text>
    <text class="page-subtitle">下面每一个按钮，都能立刻联系到能帮你的人</text>
  </view>

  <!-- 紧急热线大字卡 -->
  <view class="emergency-card fade-up delay-1" bindtap="call110" hover-class="press">
    <view class="emergency-top">
      <view class="phone-icon-window">🚨</view>
      <view class="danger-status">正在发生的暴力 · 优先拨打</view>
    </view>
    <text class="emergency-label">报警电话</text>
    <text class="emergency-number">110</text>
    <view class="emergency-action">
      <text>立即拨打</text>
      <text>›</text>
    </view>
    <text class="silent-tip">接通后先说「我被打了」+ 具体地址（不是"我们吵架了"）</text>
  </view>

  <!-- 12110 短信报警（不方便说话时） -->
  <view class="sms-card fade-up delay-1" bindtap="copySms" hover-class="press">
    <view class="sms-icon">🔇</view>
    <view class="sms-copy">
      <text class="sms-title">不方便打电话？短信 12110 报警</text>
      <text class="sms-note">点这里复制一句话话术，粘贴到短信发给 12110</text>
    </view>
    <text class="sms-act">复制</text>
  </view>

  <!-- 快速行动格 -->
  <text class="section-title-local fade-up delay-2">更多求助渠道</text>
  <view class="quick-grid fade-up delay-2">
    <view class="quick-action rights" bindtap="call" data-tel="12338" hover-class="press">
      <view class="quick-icon">⚖️</view>
      <view class="quick-copy">
        <text class="quick-title">妇女维权热线</text>
        <text class="quick-note">法律咨询 · 庇护安排 · 属地资源</text>
      </view>
      <text class="quick-value">12338</text>
    </view>
    <view class="quick-action medical" bindtap="call" data-tel="120" hover-class="press">
      <view class="quick-icon">🏥</view>
      <view class="quick-copy">
        <text class="quick-title">急救电话</text>
        <text class="quick-note">受伤需要紧急救治</text>
      </view>
      <text class="quick-value">120</text>
    </view>
    <view class="quick-action support" bindtap="call" data-tel="17701242202" hover-class="press">
      <view class="quick-icon">🤝</view>
      <view class="quick-copy">
        <text class="quick-title">源众个案热线 · 真人接听</text>
        <text class="quick-note">法律援助 · 心理支持 · 紧急救助资金（9:00-17:00）</text>
      </view>
      <text class="quick-value small">177-0124-2202</text>
    </view>
    <view class="quick-action ribbon" bindtap="call" data-tel="4000110391" hover-class="press">
      <view class="quick-icon">🎗️</view>
      <view class="quick-copy">
        <text class="quick-title">白丝带热线 · 全年无休</text>
        <text class="quick-note">8:00-22:00 · 男性受害者也可求助</text>
      </view>
      <text class="quick-value small">400-0110-391</text>
    </view>
    <view class="quick-action location" bindtap="showLocation" hover-class="press">
      <view class="quick-icon">📍</view>
      <view class="quick-copy">
        <text class="quick-title">我的当前位置</text>
        <text class="quick-note">打开地图，便于告知救助人员</text>
      </view>
      <text class="quick-value arrow">›</text>
    </view>
  </view>

  <!-- 全部机构名录入口 -->
  <view class="orgs-link fade-up delay-2" bindtap="goOrgs" hover-class="press">
    <text>📒 全部救助机构名录 · 14 家全国 + 18 家区域 + 文书模板</text>
    <text class="orgs-arrow">›</text>
  </view>

  <!-- 安全三步 -->
  <text class="section-title-local fade-up delay-3">此刻的安全三步</text>
  <view class="safety-steps fade-up delay-3">
    <view class="safety-step">
      <view class="step-icon">🚪</view>
      <text class="step-title">靠近出口</text>
      <text class="step-note">移到离大门近、有人能听见的房间</text>
    </view>
    <view class="safety-step">
      <view class="step-icon">🔪</view>
      <text class="step-title">避开危险区</text>
      <text class="step-note">远离厨房、浴室等有利器的封闭空间</text>
    </view>
    <view class="safety-step">
      <view class="step-icon">📢</view>
      <text class="step-title">大声呼救</text>
      <text class="step-note">引起邻里注意，让更多人知道</text>
    </view>
  </view>

  <!-- 紧急联系人 -->
  <text class="section-title-local fade-up delay-4">我的紧急联系人</text>
  <view class="contact-group fade-up delay-4" wx:if="{{contacts.length}}">
    <view class="contact-row" wx:for="{{contacts}}" wx:key="tel">
      <view class="contact-icon">🫂</view>
      <view class="contact-copy">
        <text>{{item.name}}</text>
        <text>{{item.tel}}</text>
      </view>
      <view class="contact-call" bindtap="call" data-tel="{{item.tel}}">拨打</view>
    </view>
  </view>
  <view class="contact-empty fade-up delay-4" wx:else bindtap="goMine">
    还没有设置紧急联系人 · 去「设置」添加 ›
  </view>

  <app-dock active="sos" />
</view>
