.home { padding: 28rpx 28rpx 0; }

/* 问候卡：带一枚"阳光"渐变光斑 */
.greet { position: relative; overflow: hidden; padding: 40rpx 36rpx; }
.greet-sun {
  position: absolute;
  right: -60rpx;
  top: -80rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(224, 138, 78, 0.28), rgba(224, 138, 78, 0));
}
.greet-hi { font-size: 42rpx; font-weight: 800; letter-spacing: 1rpx; }
.greet-sub { color: var(--muted); margin-top: 8rpx; font-size: 28rpx; }
.greet-date { margin-top: 20rpx; font-size: 22rpx; color: var(--muted); opacity: 0.8; }

/* 一键求助 */
.sos {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(135deg, #E08A4E, #C9722F);
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
  color: #FFFDF7;
}
.sos-hover { opacity: 0.92; }
.sos-icon { font-size: 64rpx; }
.sos-title { font-size: 38rpx; font-weight: 800; letter-spacing: 2rpx; }
.sos-sub { font-size: 24rpx; opacity: 0.9; margin-top: 4rpx; }

/* 功能入口 2×2 */
.grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.cell {
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 28rpx;
  box-shadow: var(--shadow);
  padding: 28rpx;
}
.cell-hover { transform: translateY(-4rpx); }
.cell-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.bg-apricot { background: var(--apricot-soft); }
.bg-sage { background: var(--sage-soft); }
.cell-name { font-size: 30rpx; font-weight: 700; margin-top: 16rpx; }
.cell-desc { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }

/* 科普流 */
.section-title { font-size: 30rpx; font-weight: 700; margin: 36rpx 4rpx 16rpx; color: var(--text); }
.feed { display: flex; flex-direction: column; gap: 20rpx; }
.k-card { padding: 26rpx 28rpx; }
.k-head { display: flex; align-items: flex-start; gap: 20rpx; }
.k-icon { font-size: 40rpx; line-height: 1.3; }
.k-texts { flex: 1; min-width: 0; }
.k-title { font-size: 30rpx; font-weight: 700; }
.k-brief { font-size: 24rpx; color: var(--muted); margin-top: 4rpx; }
.k-chevron { color: var(--muted); font-size: 36rpx; transform: rotate(90deg); transition: transform 0.2s; }
.k-chevron.open { transform: rotate(-90deg); }
.k-body { margin-top: 20rpx; border-top: 1rpx dashed var(--border); padding-top: 20rpx; }
.k-p { font-size: 26rpx; color: var(--text); margin-bottom: 14rpx; line-height: 1.75; }
.k-p:last-child { margin-bottom: 0; }
