.home { padding: 28rpx 28rpx 0; }

/* 问候卡：带一枚"阳光"渐变光斑 */
.greet { position: relative; overflow: hidden; padding: 40rpx 36rpx; }
.greet-sun {
  position: absolute;
  right: -60rpx;
  top: -80rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(155, 124, 255, 0.20), rgba(155, 124, 255, 0));
}
.greet-hi {
  font-family: "Songti SC", "STSong", "Noto Serif SC", serif;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.greet-sub { color: var(--muted); margin-top: 8rpx; font-size: 28rpx; }
.greet-date { margin-top: 20rpx; font-size: 22rpx; color: var(--muted); opacity: 0.8; }

/* 一键求助 · 暖芽淡红紧急卡 */
.sos {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--danger-soft);
  border-radius: 30rpx;
  padding: 34rpx 30rpx;
  color: var(--text);
  box-shadow: 0 18rpx 46rpx rgba(126, 53, 49, 0.08);
}
.sos-hover { opacity: 0.92; }
.sos-icon {
  width: 88rpx; height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}
.sos-title { font-size: var(--font-nav); font-weight: 800; letter-spacing: 2rpx; }
.sos-sub { font-size: var(--font-meta); color: rgba(25, 23, 28, 0.55); margin-top: 4rpx; }

/* 功能入口 2×2 */
.grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.cell {
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 28rpx;
  box-shadow: var(--shadow);
  padding: 28rpx;
}
.cell-hover { transform: translateY(-4rpx); }
.cell-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.bg-apricot { background: var(--apricot-soft); } /* 淡紫 */
.bg-sage { background: var(--sage-soft); }       /* 淡绿 */
.bg-amber { background: var(--amber-soft); }     /* 淡橙 */
.bg-rose { background: var(--danger-soft); }     /* 淡红 */
.cell-name { font-size: 30rpx; font-weight: 700; margin-top: 16rpx; }
.cell-desc { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }

/* 科普流 */
.section-title { font-size: 30rpx; font-weight: 700; margin: 36rpx 4rpx 16rpx; color: var(--text); }
.feed { display: flex; flex-direction: column; gap: 20rpx; }
.k-card { padding: 26rpx 28rpx; }
.k-head { display: flex; align-items: flex-start; gap: 20rpx; }
.k-icon { font-size: 40rpx; line-height: 1.3; }
.k-texts { flex: 1; min-width: 0; }
.k-title { font-size: 30rpx; font-weight: 700; }
.k-brief { font-size: 24rpx; color: var(--muted); margin-top: 4rpx; }
.k-chevron { color: var(--muted); font-size: 36rpx; transform: rotate(90deg); transition: transform 0.2s; }
.k-chevron.open { transform: rotate(-90deg); }
.k-body { margin-top: 20rpx; border-top: 1rpx dashed var(--border); padding-top: 20rpx; }
.k-p { font-size: 26rpx; color: var(--text); margin-bottom: 14rpx; line-height: 1.75; }
.k-p:last-child { margin-bottom: 0; }

/* 求助资源名录入口（通栏） */
.res-entry { display: flex; align-items: center; gap: 18rpx; margin-top: 24rpx; padding: 26rpx 28rpx; }
.res-icon { width: 76rpx; height: 76rpx; flex: 0 0 76rpx; display: flex; align-items: center; justify-content: center; border-radius: 24rpx; background: #eeebff; font-size: 38rpx; }
.res-texts { flex: 1; min-width: 0; }
.res-name { font-size: 30rpx; font-weight: 700; }
.res-desc { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }
.res-arrow { font-size: 36rpx; color: var(--muted); opacity: 0.6; }

/* 隐私信任条（轻量，不加卡片底） */
.trust-strip { display: flex; align-items: center; justify-content: center; gap: 10rpx; margin-top: 20rpx; padding: 6rpx 0; }
.trust-text { font-size: 22rpx; color: var(--muted); }
.trust-more { font-size: 22rpx; color: #745fc1; }
