.chat { display: flex; flex-direction: column; height: 100vh; }

/* 危机 Banner */
.crisis { padding: 22rpx 28rpx; animation: slideDown 0.3s ease; }
@keyframes slideDown { from { transform: translateY(-100%); } to { transform: translateY(0); } }
.crisis.lv2 { background: #F9EAD9; border-bottom: 2rpx solid #E8B27E; }
.crisis.lv3 { background: var(--danger-soft); border-bottom: 2rpx solid #E0917E; }
.crisis-text { font-size: 26rpx; font-weight: 600; color: var(--danger); }
.crisis-actions { display: flex; align-items: center; gap: 16rpx; margin-top: 14rpx; }
.crisis-btn {
  font-size: 26rpx;
  font-weight: 700;
  padding: 10rpx 26rpx;
  border-radius: 999rpx;
  color: #FFF6F2;
}
.b110 { background: var(--danger); }
.b12338 { background: var(--apricot-deep); }
.crisis-close { margin-left: auto; color: var(--muted); font-size: 30rpx; padding: 4rpx 12rpx; }

/* 模式切换 */
.seg {
  display: flex;
  margin: 20rpx 28rpx 0;
  background: var(--surface-2);
  border-radius: 999rpx;
  padding: 6rpx;
}
.seg-item {
  flex: 1;
  text-align: center;
  font-size: 27rpx;
  font-weight: 600;
  color: var(--muted);
  padding: 14rpx 0;
  border-radius: 999rpx;
}
.seg-item.on { background: var(--surface); color: var(--apricot-deep); box-shadow: var(--shadow); }
.notice { text-align: center; font-size: 20rpx; color: var(--muted); opacity: 0.75; padding: 12rpx 0 4rpx; }

/* 消息区 */
.msgs { flex: 1; min-height: 0; padding: 12rpx 28rpx; box-sizing: border-box; }
.welcome { text-align: center; padding: 60rpx 30rpx 30rpx; }
.w-emoji { font-size: 72rpx; }
.w-title { font-size: 36rpx; font-weight: 800; margin-top: 16rpx; }
.w-sub { font-size: 26rpx; color: var(--muted); margin-top: 10rpx; }
.chips { display: flex; flex-direction: column; gap: 16rpx; margin-top: 44rpx; }
.chip {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: 999rpx;
  padding: 18rpx 30rpx;
  font-size: 27rpx;
  color: var(--text);
  box-shadow: var(--shadow);
}

.row { display: flex; margin: 18rpx 0; }
.row.right { justify-content: flex-end; }
.row.left { justify-content: flex-start; }
.bubble {
  max-width: 78%;
  padding: 20rpx 26rpx;
  font-size: 29rpx;
  line-height: 1.7;
  word-break: break-all;
}
.bubble.user {
  background: linear-gradient(135deg, #F3C9A2, #EBB183);
  color: #4A3319;
  border-radius: 28rpx 28rpx 8rpx 28rpx;
}
.bubble.ai {
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 28rpx 28rpx 28rpx 8rpx;
  box-shadow: var(--shadow);
}

/* RAG 来源引用 */
.sources { margin-top: 16rpx; border-top: 1rpx dashed var(--border); padding-top: 12rpx; }
.src { font-size: 22rpx; color: var(--muted); margin-top: 6rpx; }
.src-ref { color: var(--sage); font-weight: 700; margin-right: 8rpx; }

/* 打字中 */
.typing { display: flex; gap: 10rpx; align-items: center; padding: 26rpx 30rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--apricot); animation: blink 1.2s infinite; }
.d2 { animation-delay: 0.2s; }
.d3 { animation-delay: 0.4s; }
@keyframes blink { 0%, 100% { opacity: 0.25; } 50% { opacity: 1; } }

/* 输入条 */
.input-bar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  background: var(--surface);
  border-top: 1rpx solid var(--border);
}
.input {
  flex: 1;
  background: var(--surface-2);
  border-radius: 999rpx;
  padding: 18rpx 30rpx;
  font-size: 29rpx;
}
.ph { color: var(--muted); }
.send {
  background: linear-gradient(135deg, var(--apricot), var(--apricot-deep));
  color: #FFFDF7;
  font-size: 28rpx;
  font-weight: 700;
  padding: 16rpx 36rpx;
  border-radius: 999rpx;
}
.send.disabled { opacity: 0.5; }

/* 结论卡片 */
.card-row { display: flex; justify-content: flex-start; margin: -4rpx 0 18rpx; }
.concl-card {
  max-width: 82%;
  background: linear-gradient(135deg, #FFF7EE, #FCEEDC);
  border: 2rpx solid var(--apricot);
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  box-shadow: var(--shadow);
}
.cc-head { font-size: 24rpx; font-weight: 700; color: var(--apricot-deep); }
.cc-body { font-size: 26rpx; line-height: 1.65; margin: 10rpx 0 18rpx; color: var(--text); }
.cc-actions { display: flex; gap: 16rpx; }
.cc-btn {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  padding: 14rpx 0;
  border-radius: 999rpx;
  background: var(--surface);
  color: var(--apricot-deep);
  border: 2rpx solid var(--apricot);
}
.cc-btn.done { background: var(--sage-soft); color: var(--sage); border-color: var(--sage); }
.cc-btn.cc-sos { background: var(--danger); color: #FFF6F2; border-color: var(--danger); }
