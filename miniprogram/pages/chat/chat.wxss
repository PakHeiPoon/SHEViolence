@import "../../styles/chat-ui.wxss";

/* 顶部会话栏 */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx;
  background: var(--surface);
  border-bottom: 1rpx solid var(--border);
}
.tb-btn { font-size: 26rpx; color: var(--apricot-deep); font-weight: 600; }
.tb-new { color: var(--sage); }
.tb-title { font-size: 30rpx; font-weight: 800; }

.notice { text-align: center; font-size: 21rpx; color: var(--muted); opacity: 0.85; padding: 12rpx 0 2rpx; }

/* 待发图片预览 */
.img-preview {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 26rpx;
  background: var(--surface);
  border-top: 1rpx solid var(--border);
}
.ip-thumb { width: 96rpx; height: 96rpx; border-radius: 14rpx; background: var(--surface-2); }
.ip-del {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: rgba(0,0,0,0.45); color: #fff; font-size: 24rpx;
  display: flex; align-items: center; justify-content: center;
}
.ip-tip { font-size: 23rpx; color: var(--muted); }

/* 结论卡片 */
.card-row { display: flex; justify-content: flex-start; margin: -4rpx 0 18rpx; }
.concl-card {
  max-width: 82%;
  background: linear-gradient(135deg, #FFF7EE, #FCEEDC);
  border: 2rpx solid var(--apricot);
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  box-shadow: var(--shadow);
}
.cc-head { font-size: 24rpx; font-weight: 700; color: var(--apricot-deep); }
.cc-body { font-size: 26rpx; line-height: 1.65; margin: 10rpx 0 18rpx; color: var(--text); }
.cc-actions { display: flex; gap: 16rpx; }
.cc-btn {
  flex: 1; text-align: center; font-size: 24rpx; font-weight: 600;
  padding: 14rpx 0; border-radius: 999rpx;
  background: var(--surface); color: var(--apricot-deep); border: 2rpx solid var(--apricot);
}
.cc-btn.done { background: var(--sage-soft); color: var(--sage); border-color: var(--sage); }
.cc-btn.cc-sos { background: var(--danger); color: #FFF6F2; border-color: var(--danger); }

/* 会话抽屉 */
.drawer-mask { position: fixed; inset: 0; background: rgba(40, 30, 20, 0.35); z-index: 900; }
.drawer {
  position: fixed; top: 0; left: 0; bottom: 0;
  width: 74%; max-width: 580rpx;
  background: var(--bg);
  z-index: 901;
  transform: translateX(-102%);
  transition: transform 0.26s ease;
  display: flex; flex-direction: column;
  box-shadow: 6rpx 0 30rpx rgba(0,0,0,0.12);
}
.drawer.open { transform: translateX(0); }
.drawer-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: calc(28rpx + env(safe-area-inset-top)) 28rpx 20rpx;
  font-size: 32rpx; font-weight: 800;
  border-bottom: 1rpx solid var(--border);
}
.drawer-new { font-size: 25rpx; color: var(--sage); font-weight: 600; }
.drawer-list { flex: 1; padding: 12rpx 20rpx; }
.sess-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 22rpx 20rpx; border-radius: 18rpx; margin-bottom: 10rpx;
  background: var(--surface); border: 1rpx solid var(--border);
}
.sess-item.active { border-color: var(--apricot); background: var(--apricot-soft); }
.sess-info { flex: 1; min-width: 0; }
.sess-title { font-size: 28rpx; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sess-time { font-size: 21rpx; color: var(--muted); margin-top: 4rpx; }
.sess-del { font-size: 23rpx; color: var(--muted); padding-left: 16rpx; }
.drawer-empty { text-align: center; color: var(--muted); font-size: 24rpx; padding: 40rpx; }
