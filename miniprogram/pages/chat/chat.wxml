<view class="chatbox">

  <!-- 顶部会话栏 -->
  <view class="topbar">
    <view class="tb-btn" bindtap="openSessions">☰ 会话</view>
    <view class="tb-title">暖暖</view>
    <view class="tb-btn tb-new" bindtap="newSession">＋ 新对话</view>
  </view>

  <!-- 危机求助 Banner -->
  <view class="crisis {{crisisLevel >= 3 ? 'lv3' : 'lv2'}}" wx:if="{{crisisLevel >= 2}}">
    <view class="crisis-text">
      {{crisisLevel >= 3 ? '我们检测到你可能正处于危险中' : '你的安全最重要'}}，需要时请立即联系：
    </view>
    <view class="crisis-actions">
      <view class="crisis-btn b110" catchtap="call110">📞 110 报警</view>
      <view class="crisis-btn b12338" catchtap="call12338">📞 12338</view>
      <view class="crisis-close" catchtap="closeBanner">✕</view>
    </view>
  </view>

  <view class="notice">🔒 对话仅保存在本机 · 可发文字或图片 · AI 建议仅供参考</view>

  <!-- 消息区 -->
  <scroll-view class="msgs" scroll-y scroll-into-view="{{toView}}" scroll-with-animation>
    <view class="welcome" wx:if="{{messages.length === 0}}">
      <view class="w-emoji">🌿</view>
      <view class="w-title">你好，我是暖暖</view>
      <view class="w-sub">这里很安全，你可以慢慢说，我会一直在。</view>
      <view class="chips">
        <view class="chip" wx:for="{{chips}}" wx:key="*this" bindtap="tapChip" data-text="{{item}}">{{item}}</view>
      </view>
    </view>

    <block wx:for="{{messages}}" wx:key="index">
      <view class="row {{item.role === 'user' ? 'right' : 'left'}}">
        <view class="bubble {{item.role === 'user' ? 'user' : 'ai'}}">
          <image wx:if="{{item.image}}" class="bubble-img" src="{{item.image}}" mode="widthFix" />
          <text wx:if="{{item.content}}">{{item.content}}</text>
          <view class="sources" wx:if="{{item.sources && item.sources.length}}">
            <view class="src" wx:for="{{item.sources}}" wx:for-item="s" wx:key="ref"
              bindtap="copySource" data-url="{{s.url || ''}}">
              <text class="src-ref">🌐 [{{s.ref}}]</text><text class="src-name">{{s.source}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="card-row" wx:if="{{item.card}}">
        <view class="concl-card">
          <view class="cc-head">💡 一条可以行动的建议</view>
          <view class="cc-body">{{item.card.summary}}</view>
          <view class="cc-actions">
            <view class="cc-btn {{item.card.saved ? 'done' : ''}}" catchtap="saveCardToEvidence" data-idx="{{index}}">{{item.card.saved ? '✓ 已存到我的记录' : '＋ 存到我的记录'}}</view>
            <view class="cc-btn cc-sos" catchtap="sosFromCard">一键求助</view>
          </view>
        </view>
      </view>
    </block>

    <view class="row left" wx:if="{{aiTyping}}">
      <view class="bubble ai typing">
        <view class="dot d1"></view><view class="dot d2"></view><view class="dot d3"></view>
        <text class="status-text" wx:if="{{agentStatus}}">{{agentStatus}}</text>
      </view>
    </view>
    <view id="anchor-bottom" style="height: 2rpx;"></view>
  </scroll-view>

  <!-- 待发图片预览 -->
  <view class="img-preview" wx:if="{{imagePath}}">
    <image class="ip-thumb" src="{{imagePath}}" mode="aspectFill" />
    <view class="ip-del" catchtap="clearImage">✕</view>
    <view class="ip-tip">图片将发给暖暖看看</view>
  </view>

  <!-- 录音提示 -->
  <view class="rec-pill" wx:if="{{recHint}}">{{recHint}}</view>

  <!-- 输入条 -->
  <view class="input-bar">
    <view class="icon-btn {{recing ? 'recing' : ''}}" bindtouchstart="voiceStart" bindtouchend="voiceStop" bindtouchcancel="voiceStop">🎤</view>
    <view class="icon-btn" hover-class="icon-btn on" bindtap="chooseImage">📷</view>
    <input class="input" value="{{inputValue}}" bindinput="onInput" confirm-type="send" bindconfirm="send"
      placeholder="想说什么都可以…" placeholder-class="ph" />
    <view class="send {{aiTyping ? 'disabled' : ''}}" bindtap="send">发送</view>
  </view>

  <!-- 会话抽屉 -->
  <view class="drawer-mask" wx:if="{{showSessions}}" bindtap="closeSessions"></view>
  <view class="drawer {{showSessions ? 'open' : ''}}">
    <view class="drawer-head">
      <text>我的会话</text>
      <view class="drawer-new" bindtap="newSession">＋ 新对话</view>
    </view>
    <scroll-view class="drawer-list" scroll-y>
      <view class="sess-item {{item.active ? 'active' : ''}}" wx:for="{{sessions}}" wx:key="id"
        bindtap="switchSession" data-id="{{item.id}}">
        <view class="sess-info">
          <view class="sess-title">{{item.title}}</view>
          <view class="sess-time">{{item.time}}</view>
        </view>
        <view class="sess-del" catchtap="delSession" data-id="{{item.id}}">删除</view>
      </view>
      <view class="drawer-empty" wx:if="{{sessions.length === 0}}">还没有会话</view>
    </scroll-view>
  </view>

  <escape-btn />
</view>
