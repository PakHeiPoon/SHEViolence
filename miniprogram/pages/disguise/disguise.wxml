<view class="ledger">

  <!-- 月度汇总（连点3次可解锁·备用入口） -->
  <view class="summary" bindtap="onTitleTap">
    <view class="summary-label">本月支出（元）</view>
    <view class="summary-num">{{total}}</view>
    <view class="summary-sub">共 {{records.length}} 笔 · 点击下方记一笔</view>
  </view>

  <!-- 记账表单 -->
  <view class="form">
    <view class="form-row">
      <view class="form-label">类别</view>
      <picker class="form-picker" range="{{cats}}" value="{{catIndex}}" bindchange="onCatChange">
        <view class="picker-value">{{cats[catIndex]}} <text class="arrow">›</text></view>
      </picker>
    </view>
    <view class="form-row">
      <view class="form-label">金额</view>
      <input class="form-input" type="digit" value="{{amount}}" placeholder="0.00"
        placeholder-class="ph" bindinput="onAmount" bindconfirm="onConfirm" />
    </view>
    <view class="form-row">
      <view class="form-label">备注</view>
      <input class="form-input" value="{{note}}" placeholder="选填" placeholder-class="ph" bindinput="onNote" />
    </view>
    <button class="add-btn" bindtap="onConfirm">记一笔</button>
  </view>

  <!-- 流水列表 -->
  <view class="list">
    <view class="list-title">最近记录</view>
    <view class="row" wx:for="{{records}}" wx:key="index">
      <view class="row-left">
        <view class="row-cat">{{item.cat}}</view>
        <view class="row-meta">{{item.date}}<text wx:if="{{item.note}}"> · {{item.note}}</text></view>
      </view>
      <view class="row-amt">-{{item.amount}}</view>
    </view>
  </view>

  <view class="foot">简易记账 v1.2</view>
</view>
