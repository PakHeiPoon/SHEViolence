.ev { padding: 28rpx; }

/* 顶部提示 */
.tip { display: flex; gap: 20rpx; padding: 26rpx 28rpx; }
.tip-icon { font-size: 44rpx; }
.tip-title { font-size: 29rpx; font-weight: 700; }
.tip-sub { font-size: 23rpx; color: var(--muted); margin-top: 6rpx; line-height: 1.7; }

/* 上传按钮 */
.add {
  margin-top: 24rpx;
  border: 3rpx dashed var(--apricot);
  border-radius: 28rpx;
  background: var(--apricot-soft);
  padding: 44rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.add.busy { opacity: 0.8; }
.add-icon { font-size: 56rpx; }
.spin { animation: spin 1.6s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.add-text { font-size: 27rpx; color: var(--apricot-deep); font-weight: 600; }

/* 草稿确认卡 */
.draft { margin-top: 24rpx; padding: 28rpx; border: 2rpx solid var(--apricot); }
.draft-head { display: flex; align-items: center; gap: 20rpx; margin-bottom: 18rpx; }
.draft-img { width: 96rpx; height: 96rpx; border-radius: 16rpx; background: var(--surface-2); }
.draft-title { font-size: 29rpx; font-weight: 700; }
.d-row { display: flex; gap: 16rpx; margin-top: 14rpx; }
.d-label { flex-shrink: 0; font-size: 23rpx; color: var(--apricot-deep); font-weight: 700; width: 110rpx; margin-top: 4rpx; }
.d-val { font-size: 26rpx; line-height: 1.7; flex: 1; }
.d-note { font-size: 21rpx; color: var(--muted); text-align: center; margin-top: 20rpx; }
.d-btns { display: flex; gap: 18rpx; margin-top: 20rpx; }
.d-btns .btn { flex: 1; font-size: 27rpx; padding: 16rpx 0; }

/* 时间线 */
.tl-title { font-size: 30rpx; font-weight: 700; margin: 36rpx 4rpx 16rpx; }
.tl { display: flex; flex-direction: column; gap: 20rpx; }
.item { padding: 26rpx 28rpx; }
.item-head { display: flex; align-items: center; gap: 16rpx; }
.item-date { font-size: 24rpx; color: var(--muted); font-weight: 600; }
.item-del { margin-left: auto; font-size: 22rpx; color: var(--muted); }
.item-title { font-size: 29rpx; font-weight: 700; margin-top: 12rpx; }
.item-img { width: 100%; height: 240rpx; border-radius: 20rpx; margin-top: 16rpx; background: var(--surface-2); }
.item-desc { font-size: 26rpx; line-height: 1.75; margin-top: 14rpx; }
.item-extra { font-size: 23rpx; color: var(--muted); margin-top: 10rpx; line-height: 1.6; }

/* 空状态 */
.empty { text-align: center; padding: 80rpx 40rpx; }
.empty-emoji { font-size: 72rpx; }
.empty-text { font-size: 26rpx; color: var(--muted); margin-top: 16rpx; }
